# ==========================================
# VARIABLES DE ENTORNO - RAILWAY DEPLOYMENT
# ==========================================

# Django Secret Key (generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DJANGO_SECRET_KEY=tu-secret-key-aqui

# Debug (False en producción)
DJANGO_DEBUG=False

# Hosts permitidos (separados por coma)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# CORS - URLs de tu frontend Firebase
CORS_ALLOWED_ORIGINS=https://tu-app.web.app,https://tu-app.firebaseapp.com
CORS_ALLOW_ALL_ORIGINS=False

# ==========================================
# NOTAS:
# ==========================================
# - Railway proporciona DATABASE_URL automáticamente
# - No necesitas configurar PostgreSQL manualmente
# - Agrega estas variables en Railway Dashboard > Variables
# ==========================================
